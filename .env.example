# Required: a Moralis API key for DeFi (Wallet) reads.
MORALIS_API_KEY=

# Optional: overrides the default public RPCs used for DeFi reads.
MONAD_RPC_URL=
ETHEREUM_RPC_URL=

# Optional: enables Aave on Monad when official deployment addresses are known.
AAVE_MONAD_POOL_ADDRESS=
AAVE_MONAD_ORACLE_ADDRESS=
AAVE_MONAD_PROTOCOL_DATA_PROVIDER_ADDRESS=

# Optional: enables read-only OKX trading and funding balances.
# Configure these here, then restart the backend. The OKX source is created automatically.
# Account label is arbitrary; the key, secret, and passphrase come from OKX API key setup.
OKX_ACCOUNT_LABEL=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# Optional: For Perpl
PERPL_ACCOUNT_1_WALLET_ADDRESS=
PERPL_ACCOUNT_1_API_KEY=
PERPL_ACCOUNT_1_API_KEY_SECRET=
